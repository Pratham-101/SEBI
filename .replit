run = "uvicorn app.main:app --host 0.0.0.0 --port 8080"
entrypoint = "app/main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-24_05"

[env]
USE_SYNC_PIPELINE = "true"
# Install browsers to a fixed, persisted path (not the ephemeral default cache)
# so the build-time install is still present at run time.
PLAYWRIGHT_BROWSERS_PATH = "/home/runner/workspace/.pw-browsers"

[deployment]
# Build step installs Chromium ONCE. Run step only starts the server so the
# port opens immediately and Replit's healthcheck passes (no restart loop).
build = ["sh", "-c", "PLAYWRIGHT_BROWSERS_PATH=/home/runner/workspace/.pw-browsers pip install -r requirements.txt && PLAYWRIGHT_BROWSERS_PATH=/home/runner/workspace/.pw-browsers python -m playwright install chromium"]
run = ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port 8080"]
deploymentTarget = "gce"

[[ports]]
localPort = 8080
externalPort = 80
