# =============================================================================
# RegOps OS — copy to .env and fill secrets
# =============================================================================

ACTIVE_REGULATOR=SEBI
REGOPS_MULTI_AGENT=true

# LLM provider: openai | groq  (Groq is OpenAI-API-compatible, has a free daily tier)
LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# Groq free tier — create ONE key at https://console.groq.com/keys (it does not
# rotate; only the daily quota resets automatically). Set LLM_PROVIDER=groq to use it.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

DEVREV_API_TOKEN=
DEVREV_BASE_URL=https://api.devrev.ai
# Required for ticket creation — product/capability part DON id (discover via scripts/verify_devrev.py)
DEVREV_DEFAULT_PART_ID=
# Optional: default owner dev-user DON id
DEVREV_DEFAULT_OWNER_ID=
# Set true only if your DevRev org accepts priority on tickets (p0-p3)
DEVREV_SEND_PRIORITY_FIELD=false
# DevRev workspace URL for Copilot ticket links (e.g. https://app.devrev.ai/your-org)
DEVREV_WORKSPACE_URL=
# DevRev group DON ids for the 6 canonical routing teams (create groups in DevRev UI first)
DEVREV_GROUP_LEGAL=
DEVREV_GROUP_COMPLIANCE=
DEVREV_GROUP_FINANCE=
DEVREV_GROUP_OPERATIONS=
DEVREV_GROUP_INFOSEC=
DEVREV_GROUP_EXECUTIVE=

DATABASE_URL=postgresql+psycopg2://sebi:sebi@postgres:5432/sebi_regulatory
# On Replit (which reserves DATABASE_URL), set APP_DATABASE_URL instead. It wins
# over DATABASE_URL and accepts a plain Neon postgresql:// URL (auto-normalized).
APP_DATABASE_URL=
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

CRON_INTERVAL_MINUTES=5
SEBI_SCRAPE_LIMIT=25
PIPELINE_BACKLOG_BATCH_SIZE=25
SEBI_LISTING_URL=https://www.sebi.gov.in/sebiweb/home/HomeAction.do?doListingAll=yes

LOG_LEVEL=INFO
ENVIRONMENT=development

# Governance
AI_CONFIDENCE_THRESHOLD=0.75
HUMAN_REVIEW_CONFIDENCE_THRESHOLD=0.55

# Optional alerts
SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=

# HTTP timeouts (seconds)
HTTP_TIMEOUT_SECONDS=60
DEVREV_TIMEOUT_SECONDS=30

# Copilot web search (duckduckgo = no key required; serpapi needs WEB_SEARCH_API_KEY)
WEB_SEARCH_PROVIDER=duckduckgo
WEB_SEARCH_API_KEY=

# DevRev webhook for /ask copilot (register in DevRev webhook settings)
DEVREV_WEBHOOK_SECRET=

# =============================================================================
# Person-level assignment (assign tickets to a real DevRev user, not just a team)
# =============================================================================
ASSIGNMENT_ENABLED=true
# Roster of assignable people; edit data/roster.json then run scripts/sync_roster.py
ASSIGNMENT_ROSTER_PATH=data/roster.json
# Candidate scoring weights: score = skill^w x availability^w x seniority^w
ASSIGNMENT_SKILL_WEIGHT=0.5
ASSIGNMENT_LOAD_WEIGHT=0.35
ASSIGNMENT_SENIORITY_WEIGHT=0.15
# Pull live open-ticket counts from DevRev works.list for load balancing
ASSIGNMENT_USE_LIVE_LOAD=true
# Post a manager-escalation comment on CRITICAL tickets
ASSIGNMENT_NOTIFY_MANAGER_ON_CRITICAL=true

# =============================================================================
# Applicability scoring (filter SEBI items irrelevant to your org)
# =============================================================================
APPLICABILITY_ENABLED=true
APPLICABILITY_PROFILE_PATH=data/org_profile.json
# Items scoring below this get no ticket (logged as not_applicable)
APPLICABILITY_TICKET_MIN_SCORE=0.35

# =============================================================================
# Richer ticket model
# =============================================================================
# Namespaced tag taxonomy (reg:, domain:, type:, pri:, team:, deadline:, ...)
DEVREV_NAMESPACED_TAGS=true
# Custom fields require matching ctype fields in your DevRev tenant — off by default
DEVREV_SEND_CUSTOM_FIELDS=false
# Due dates require a date field on the work item in your tenant — off by default
DEVREV_SEND_DUE_DATES=false
DEVREV_DUE_DATE_FIELD=target_close_date
# Internal SLA lead time (days before the regulatory deadline) by priority
DEVREV_SLA_LEAD_DAYS_CRITICAL=2
DEVREV_SLA_LEAD_DAYS_HIGH=5
DEVREV_SLA_LEAD_DAYS_DEFAULT=10
DEVREV_LINK_RELATED_TICKETS=true

# =============================================================================
# Grounded AI extraction (citations + verify pass for HIGH/CRITICAL)
# =============================================================================
GROUNDED_EXTRACTION_ENABLED=true
AI_VERIFY_HIGH_CRITICAL=true
# Model for the verify pass (blank = same as OPENAI_MODEL)
OPENAI_VERIFY_MODEL=
# Min fraction of dates whose verbatim citation must appear in source
CITATION_MIN_SUPPORTED_RATIO=0.5
